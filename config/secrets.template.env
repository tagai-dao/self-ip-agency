# Self-IP Agency — Secrets Reference Template
# Reference only. The canonical onboarding flow writes real values into:
#   <workspace>/skills/tagclaw/.env
#   <workspace>/skills/tagclaw-wallet/.env
# Do not pre-create placeholder env files inside those skill directories before onboarding.
#
# IMPORTANT: NEVER commit real secrets to git.

# ── TagClaw skill env (<workspace>/skills/tagclaw/.env) ───────────────────
# Your TagClaw API key. Produced by the TagClaw register flow.
TAGCLAW_API_KEY=<YOUR_TAGCLAW_API_KEY>

# ── tagclaw-wallet env (<workspace>/skills/tagclaw-wallet/.env) ────────────
# The wallet setup flow generates these fields. Keep them in the wallet repo .env.
TAGCLAW_ETH_ADDR=<YOUR_0x_WALLET_ADDRESS>
TAGCLAW_EVM_PRIVATE_KEY=<YOUR_BSC_PRIVATE_KEY>
TAGCLAW_STEEM_POSTING_PUB=<YOUR_STEEM_POSTING_PUB>
TAGCLAW_STEEM_POSTING_PRI=<YOUR_STEEM_POSTING_PRI>
TAGCLAW_STEEM_OWNER=<YOUR_STEEM_OWNER>
TAGCLAW_STEEM_ACTIVE=<YOUR_STEEM_ACTIVE>
TAGCLAW_STEEM_MEMO=<YOUR_STEEM_MEMO>

# ── Optional X credentials (separate from TagClaw skill state) ─────────────
X_BEARER_TOKEN=<YOUR_X_BEARER_TOKEN>
X_API_KEY=<YOUR_X_API_KEY>
X_API_SECRET=<YOUR_X_API_SECRET>
X_ACCESS_TOKEN=<YOUR_X_ACCESS_TOKEN>
X_ACCESS_TOKEN_SECRET=<YOUR_X_ACCESS_TOKEN_SECRET>

# ── Optional operator notifications ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TELEGRAM_CHAT_ID=<YOUR_TELEGRAM_CHAT_ID>
