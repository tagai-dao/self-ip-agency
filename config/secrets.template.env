# Self-IP Agency — Secrets Template
# Copy this file to config/secrets.env (or ~/.config/tagclaw/secrets.env)
# and fill in your actual values.
#
# IMPORTANT: NEVER commit secrets.env or credentials.json to git.
# This template file is safe to commit (all values are placeholders).

# ── TagClaw API ─────────────────────────────────────────────────────────────
# Your TagClaw API key. Find it at https://tagclaw.com/account/api
TAGCLAW_API_KEY=<YOUR_TAGCLAW_API_KEY>

# ── BSC Wallet ──────────────────────────────────────────────────────────────
# BSC wallet private key (hex, with or without 0x prefix).
# Used by the Trader agent for on-chain operations.
# CAUTION: This is a hot wallet — do NOT use your primary cold wallet.
BSC_PRIVATE_KEY=<YOUR_BSC_PRIVATE_KEY>

# Your BSC wallet address (public, used for display)
BSC_WALLET_ADDRESS=<YOUR_0x_WALLET_ADDRESS>

# ── X (Twitter) ─────────────────────────────────────────────────────────────
# Optional: X API bearer token for enhanced feed access.
# Without this, the agent uses TagClaw's feed API only (no direct X API).
X_BEARER_TOKEN=<YOUR_X_BEARER_TOKEN>

# Optional: X OAuth credentials for posting on behalf of the owner account
X_API_KEY=<YOUR_X_API_KEY>
X_API_SECRET=<YOUR_X_API_SECRET>
X_ACCESS_TOKEN=<YOUR_X_ACCESS_TOKEN>
X_ACCESS_TOKEN_SECRET=<YOUR_X_ACCESS_TOKEN_SECRET>

# ── OpenClaw ────────────────────────────────────────────────────────────────
# OpenClaw workspace path (default: ~/.openclaw/workspace)
OPENCLAW_WORKSPACE=~/.openclaw/workspace

# ── Telegram (optional) ─────────────────────────────────────────────────────
# Telegram bot token for operator notifications (optional).
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TELEGRAM_CHAT_ID=<YOUR_TELEGRAM_CHAT_ID>
